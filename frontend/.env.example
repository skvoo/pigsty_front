# Подключение к БД app на Pigsty (PgBouncer).
# Скопировать в .env.local для разработки.
# В Vercel: Project → Settings → Environment Variables → DATABASE_URL

# Формат (замените PASSWORD на пароль dbuser_app из pigsty.yml):
# DATABASE_URL=postgresql://dbuser_app:PASSWORD@104.223.25.234:6432/app

DATABASE_URL=

# Тестовая миграция Supabase → Pigsty: две БД (GD-lounge, imperial)
# Пользователи и пароли — в pigsty.yml (pg_users), порт 6432 (PgBouncer)
# DATABASE_URL_GDLOUNGE=postgresql://USER:PASSWORD@104.223.25.234:6432/gdloungedb
# DATABASE_URL_IMPERIAL=postgresql://USER:PASSWORD@104.223.25.234:6432/imperialdb

# MinIO (загрузка файлов): один бакет на деплой или переопределение через ?bucket=
# S3_ENDPOINT=http://104.223.25.234:9000
# S3_BUCKET=gd-lounge-assets
# S3_ACCESS_KEY=s3user_gdlounge
# S3_SECRET_KEY=...
# S3_PUBLIC_URL=http://104.223.25.234:9000/gd-lounge-assets
