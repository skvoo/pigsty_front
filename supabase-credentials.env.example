# Учётные данные Supabase Cloud для миграции
# Скопируйте этот файл в supabase-credentials.env и заполните значения.
# Файл supabase-credentials.env не коммитится в git.

# --- GD-lounge (проект 1) ---
SUPABASE_GDLOUNGE_REF=your-project-ref
SUPABASE_GDLOUNGE_PASSWORD=your-database-password
# Service role key for Storage migration (Dashboard → Project Settings → API → service_role)
# SUPABASE_GDLOUNGE_SERVICE_KEY=eyJhbGc...
# Session pooler для IPv4 (взять в Connect → Session pooler), например aws-1-ap-south-1.pooler.supabase.com
SUPABASE_GDLOUNGE_POOLER_HOST=

# --- imperial (проект 2) ---
SUPABASE_IMPERIAL_REF=your-project-ref
SUPABASE_IMPERIAL_PASSWORD=your-database-password
# Service role key for Storage migration (Dashboard → Project Settings → API → service_role)
# SUPABASE_IMPERIAL_SERVICE_KEY=eyJhbGc...

# Connection string Supabase: postgresql://postgres.REF:PASSWORD@db.REF.supabase.com:5432/postgres

# --- Pigsty (для pg_restore) ---
PIGSTY_HOST=104.223.25.234
PIGSTY_POSTGRES_PASSWORD=
